---
interface Props {
  as?: string;
  class?: string;
}

const { as: Tag = 'div', class: className = '' } = Astro.props;
---

<Tag class:list={['container-x', className]}>
  <slot />
</Tag>

<style>
  .container-x {
    width: 100%;
    max-width: 1280px;
    margin-inline: auto;
    padding-inline: clamp(1rem, 3vw, 2rem);
  }
</style>
