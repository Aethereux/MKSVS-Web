---
type Variant = 'primary' | 'ghost' | 'accent';
type Size = 'sm' | 'md';

interface Props {
  href?: string;
  variant?: Variant;
  size?: Size;
  type?: 'button' | 'submit';
  class?: string;
  [key: string]: unknown;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  type = 'button',
  class: className = '',
  ...rest
} = Astro.props;

const Tag = href ? 'a' : 'button';
const props = href ? { href, ...rest } : { type, ...rest };
---

<Tag
  class:list={['btn', `btn-${variant}`, `btn-${size}`, className]}
  {...props}
>
  <slot />
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    border-radius: var(--radius);
    font-weight: 600;
    letter-spacing: -0.005em;
    white-space: nowrap;
    text-decoration: none;
    transition: transform 0.18s var(--ease-out-expo),
                background 0.18s,
                box-shadow 0.18s,
                border-color 0.18s;
    cursor: pointer;
    border: 0;
  }

  .btn-md {
    padding: 0.75rem 1.25rem;
    font-size: 0.9375rem;
    min-height: 44px;
  }

  .btn-sm {
    padding: 0.5rem 0.875rem;
    font-size: 0.8125rem;
    min-height: 36px;
  }

  .btn-primary {
    background: var(--color-primary);
    color: var(--color-primary-foreground);
    box-shadow:
      0 1px 0 hsl(0 0% 100% / 0.1) inset,
      0 0 0 1px hsl(174 100% 29% / 0.4),
      0 8px 24px -8px hsl(174 100% 29% / 0.5);
  }

  .btn-primary:hover {
    transform: translateY(-1px);
    box-shadow:
      0 1px 0 hsl(0 0% 100% / 0.15) inset,
      0 0 0 1px hsl(174 100% 29% / 0.6),
      0 12px 28px -8px hsl(174 100% 29% / 0.6);
  }

  .btn-accent {
    background: var(--color-accent);
    color: var(--color-accent-foreground);
    box-shadow:
      0 1px 0 hsl(0 0% 100% / 0.1) inset,
      0 0 0 1px hsl(11 100% 37% / 0.4),
      0 8px 24px -8px hsl(11 100% 37% / 0.5);
  }

  .btn-accent:hover {
    transform: translateY(-1px);
  }

  .btn-ghost {
    background: hsl(var(--color-muted) / 0.5);
    background: color-mix(in srgb, var(--color-muted) 50%, transparent);
    color: var(--color-foreground);
    border: 1px solid var(--color-border);
  }

  .btn-ghost:hover {
    background: var(--color-muted);
    transform: translateY(-1px);
  }

  .btn:active {
    transform: translateY(0);
  }
</style>
