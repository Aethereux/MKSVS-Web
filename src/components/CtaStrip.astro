---
import Container from './ui/Container.astro';
import Button from './ui/Button.astro';
import Icon from './Icon.astro';
import ScrollReveal from './ScrollReveal.astro';

interface Props {
  title?: string;
  subtitle?: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  title = "Need a locksmith now?",
  subtitle = "We answer 24/7 across Metro Manila and nearby provinces.",
  primaryHref = '/contact',
  primaryLabel = 'Contact us',
  secondaryHref = 'tel:+6388935297',
  secondaryLabel = 'Call (8) 893-5297',
} = Astro.props;
---

<section class="cta-strip">
  <Container>
    <ScrollReveal class="cta-card">
      <div class="cta-bg" aria-hidden="true"></div>
      <div class="cta-content">
        <div>
          <h2 class="cta-title text-balance">{title}</h2>
          <p class="cta-subtitle text-pretty">{subtitle}</p>
        </div>
        <div class="cta-actions">
          <Button href={primaryHref} variant="primary">
            {primaryLabel}
            <Icon name="arrow-right" size={16} stroke={2.5} />
          </Button>
          <Button href={secondaryHref} variant="ghost">
            <Icon name="phone" size={16} />
            {secondaryLabel}
          </Button>
        </div>
      </div>
    </ScrollReveal>
  </Container>
</section>

<style>
  .cta-strip {
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  :global(.cta-card) {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border);
    background: var(--color-card);
    padding: clamp(2rem, 5vw, 3rem);
  }

  .cta-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      radial-gradient(
        ellipse 60% 80% at 90% 0%,
        color-mix(in srgb, var(--color-primary) 18%, transparent),
        transparent 60%
      ),
      radial-gradient(
        ellipse 50% 60% at 10% 100%,
        color-mix(in srgb, var(--color-accent) 14%, transparent),
        transparent 60%
      );
  }

  .cta-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: flex-start;
  }

  @media (min-width: 768px) {
    .cta-content {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  .cta-title {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0;
    max-width: 22ch;
  }

  .cta-subtitle {
    color: var(--color-muted-foreground);
    font-size: 1rem;
    max-width: 42ch;
    margin-top: 0.5rem;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
</style>
