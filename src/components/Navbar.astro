---
import Container from './ui/Container.astro';
import Button from './ui/Button.astro';
import ThemeToggle from './ThemeToggle.astro';

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);

const links = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/services', label: 'Services' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="navbar">
  <Container class="nav-inner">
    <a href="/" class="brand" aria-label="MKSVS Enterprise Corporation — home">
      <span class="brand-mark" aria-hidden="true"></span>
    </a>

    <nav aria-label="Primary">
      <ul class="nav-links">
        {links.map((link) => (
          <li>
            <a
              href={link.href}
              class="nav-link"
              aria-current={isActive(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="nav-actions">
      <ThemeToggle />
      <button class="menu-btn" id="menu-btn" aria-label="Toggle menu" aria-expanded="false">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
      <Button href="/contact" variant="primary" size="sm" class="cta">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="14" height="14">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
        </svg>
        Call us
      </Button>
    </div>
  </Container>

  <div class="mobile-drawer" id="mobile-drawer" data-open="false">
    <ul>
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class="drawer-link"
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-background) 70%, transparent);
    backdrop-filter: blur(16px) saturate(180%);
    -webkit-backdrop-filter: blur(16px) saturate(180%);
    border-bottom: 1px solid color-mix(in srgb, var(--color-border) 60%, transparent);
  }

  :global(.nav-inner) {
    display: flex !important;
    align-items: center;
    justify-content: space-between;
    padding-block: 0.875rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    font-size: 1.125rem;
    color: var(--color-foreground);
    text-decoration: none;
  }

  .brand-mark {
    width: 40px;
    height: 40px;
    display: block;
    flex-shrink: 0;
    background-image: var(--logo-mark);
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
  }

  .nav-links {
    display: none;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media (min-width: 768px) {
    .nav-links {
      display: flex;
    }
  }

  .nav-link {
    position: relative;
    display: inline-block;
    padding: 0.5rem 0.875rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-muted-foreground);
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-link:hover,
  .nav-link[aria-current='page'] {
    color: var(--color-foreground);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: 50%;
    width: 0;
    height: 2px;
    background: var(--color-primary);
    transition: width 0.3s var(--ease-out-expo),
                left 0.3s var(--ease-out-expo);
  }

  .nav-link:hover::after,
  .nav-link[aria-current='page']::after {
    width: calc(100% - 1.75rem);
    left: 0.875rem;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .menu-btn {
    width: 40px;
    height: 40px;
    display: grid;
    place-items: center;
    border-radius: var(--radius-sm);
    color: var(--color-muted-foreground);
    background: transparent;
    border: 0;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }

  .menu-btn:hover {
    background: var(--color-muted);
    color: var(--color-foreground);
  }

  @media (min-width: 768px) {
    .menu-btn { display: none; }
  }

  @media (max-width: 480px) {
    :global(.cta .cta-label),
    :global(.cta) span:not([class]) {
      display: none;
    }
  }

  .mobile-drawer {
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.35s var(--ease-out-expo);
    border-top: 1px solid var(--color-border);
  }

  .mobile-drawer[data-open='true'] {
    max-height: 320px;
  }

  .mobile-drawer ul {
    list-style: none;
    margin: 0;
    padding: 0.5rem clamp(1rem, 3vw, 2rem) 1rem;
    display: flex;
    flex-direction: column;
  }

  .drawer-link {
    display: block;
    padding: 0.875rem 0.5rem;
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-foreground);
    border-radius: var(--radius-sm);
    text-decoration: none;
    min-height: 44px;
    transition: background 0.15s, color 0.15s;
  }

  .drawer-link:hover {
    background: var(--color-muted);
  }

  .drawer-link[aria-current='page'] {
    color: var(--color-primary);
  }

  @media (min-width: 768px) {
    .mobile-drawer { display: none; }
  }
</style>

<script>
  const init = () => {
    const btn = document.getElementById('menu-btn');
    const drawer = document.getElementById('mobile-drawer');
    if (!btn || !drawer || btn.dataset.bound === '1') return;
    btn.dataset.bound = '1';

    btn.addEventListener('click', () => {
      const open = drawer.dataset.open === 'true';
      drawer.dataset.open = open ? 'false' : 'true';
      btn.setAttribute('aria-expanded', open ? 'false' : 'true');
    });

    drawer.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => {
        drawer.dataset.open = 'false';
        btn.setAttribute('aria-expanded', 'false');
      })
    );
  };

  init();
  document.addEventListener('astro:page-load', init);
</script>
