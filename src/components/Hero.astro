---
import Container from './ui/Container.astro';
import Button from './ui/Button.astro';
import Icon from './Icon.astro';
---

<section class="hero">
  <div class="hero-bg" aria-hidden="true"></div>
  <div class="hero-grid" aria-hidden="true"></div>

  <Container class="hero-inner">
    <div class="hero-copy">
      <span class="eyebrow">
        <span class="eyebrow-dot animate-pulse-dot"></span>
        24/7 service · Metro Manila
      </span>

      <h1 class="text-balance">
        Locks, keys, vaults — <em class="gradient-text">solved.</em>
      </h1>

      <p class="hero-lead">
        MKSVS Enterprise Corporation has been Makati's licensed professional
        locksmith since 1994. Residential, commercial, automotive, and
        safe-vault services delivered by skilled technicians anywhere in
        Metro Manila and nearby provinces.
      </p>

      <div class="hero-ctas">
        <Button href="/services" variant="primary">
          Explore services
          <Icon name="arrow-right" size={16} stroke={2.5} />
        </Button>
        <Button href="/contact" variant="ghost">
          Get in touch
        </Button>
      </div>

      <dl class="trust-strip">
        <div>
          <dt class="trust-num">30+</dt>
          <dd class="trust-label">Years of service</dd>
        </div>
        <div>
          <dt class="trust-num">6</dt>
          <dd class="trust-label">Service lines</dd>
        </div>
        <div>
          <dt class="trust-num">24/7</dt>
          <dd class="trust-label">Emergency response</dd>
        </div>
      </dl>
    </div>

    <div class="hero-visual" aria-hidden="true">
      <div class="hero-card hero-card-main">
        <Icon name="lock" size={120} stroke={1.5} />
      </div>

      <div class="hero-card hero-card-floating">
        <span class="floating-pill">
          <span class="live-dot animate-pulse-dot"></span>
          On call
        </span>
        <div>
          <div class="floating-num">~15min</div>
          <div class="floating-sub">Avg. response time</div>
        </div>
      </div>

      <div class="hero-card hero-card-badge">
        <span class="floating-pill">Established 1994</span>
        <div class="floating-sub">
          Trained by SECURTECH (Texas) &amp; MANTON (Hong Kong)
        </div>
      </div>
    </div>
  </Container>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(4rem, 12vh, 8rem) clamp(3rem, 10vh, 6rem);
    isolation: isolate;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -2;
    background:
      radial-gradient(ellipse 80% 60% at 20% 0%,
        color-mix(in srgb, var(--color-primary) 15%, transparent),
        transparent 60%),
      radial-gradient(ellipse 60% 50% at 80% 100%,
        color-mix(in srgb, var(--color-accent) 12%, transparent),
        transparent 60%),
      var(--color-background);
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    z-index: -1;
    background-image:
      linear-gradient(to right,
        color-mix(in srgb, var(--color-border) 40%, transparent) 1px,
        transparent 1px),
      linear-gradient(to bottom,
        color-mix(in srgb, var(--color-border) 40%, transparent) 1px,
        transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse at center, black 0%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 0%, transparent 70%);
  }

  :global(.hero-inner) {
    display: grid !important;
    gap: 4rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    :global(.hero-inner) {
      grid-template-columns: 1.1fr 1fr !important;
    }
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.875rem;
    background: color-mix(in srgb, var(--color-muted) 60%, transparent);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--color-muted-foreground);
    margin-bottom: 1.5rem;
  }

  .eyebrow-dot {
    width: 6px;
    height: 6px;
    background: var(--color-primary);
    border-radius: 50%;
    box-shadow: 0 0 8px var(--color-primary);
  }

  h1 {
    font-size: clamp(2.5rem, 6.5vw, 4.75rem);
    font-weight: 800;
    line-height: 1.02;
    letter-spacing: -0.04em;
    margin-bottom: 1.5rem;
    max-width: 18ch;
  }

  h1 em {
    font-style: normal;
  }

  .hero-lead {
    font-size: clamp(1rem, 1.4vw, 1.125rem);
    color: var(--color-muted-foreground);
    max-width: 52ch;
    margin-bottom: 2.5rem;
    line-height: 1.6;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 3rem;
  }

  .trust-strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    max-width: 36rem;
    margin: 0;
  }

  .trust-num {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    background: linear-gradient(135deg,
      var(--color-foreground),
      var(--color-muted-foreground));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    margin: 0;
  }

  .trust-label {
    font-size: 0.75rem;
    color: var(--color-muted-foreground);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    margin: 0;
  }

  /* Visual */
  .hero-visual {
    position: relative;
    aspect-ratio: 1 / 1;
    max-width: 540px;
    margin-inline: auto;
    width: 100%;
  }

  .hero-card {
    position: absolute;
    border-radius: var(--radius-lg);
    background: var(--color-card);
    border: 1px solid var(--color-border);
    overflow: hidden;
    box-shadow:
      0 1px 0 hsl(0 0% 100% / 0.04) inset,
      0 30px 80px -20px hsl(0 0% 0% / 0.6);
  }

  .hero-card-main {
    inset: 8% 12% 18% 8%;
    background:
      linear-gradient(135deg,
        color-mix(in srgb, var(--color-primary) 20%, transparent),
        color-mix(in srgb, var(--color-accent) 15%, transparent)),
      var(--color-card);
    display: grid;
    place-items: center;
    animation: float 6s ease-in-out infinite;
  }

  .hero-card-main :global(svg) {
    width: 50%;
    height: 50%;
    color: var(--color-primary);
    filter: drop-shadow(0 0 24px color-mix(in srgb, var(--color-primary) 50%, transparent));
  }

  .hero-card-floating {
    inset: 50% 0 10% 60%;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    animation: float 7s ease-in-out infinite reverse;
    animation-delay: -2s;
  }

  .hero-card-badge {
    inset: 0 50% 70% 0;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    animation: float 8s ease-in-out infinite;
    animation-delay: -4s;
  }

  .floating-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.625rem;
    background: color-mix(in srgb, var(--color-muted) 60%, transparent);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-size: 0.6875rem;
    color: var(--color-muted-foreground);
    font-weight: 600;
    width: fit-content;
  }

  .live-dot {
    width: 8px;
    height: 8px;
    background: var(--color-success);
    border-radius: 50%;
    box-shadow: 0 0 12px var(--color-success);
  }

  .floating-num {
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .floating-sub {
    font-size: 0.6875rem;
    color: var(--color-muted-foreground);
    line-height: 1.4;
    margin-top: 0.25rem;
  }
</style>
